<?xml version="1.0" encoding="UTF-8" ?>
<Mission xmlns="http://ProjectMalmo.microsoft.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <About>
    <Summary>mine stone</Summary>
  </About>

  <ModSettings>
    <MsPerTick>10</MsPerTick>
  </ModSettings>

  <ServerSection>
    <ServerHandlers>
      <FlatWorldGenerator generatorString="3;7,5*1,2*3,2;3;,biome_1"/>
      <DrawingDecorator>
        <DrawCuboid x1="-20" y1="7" z1="-20" x2="20" y2="7" z2="20" type="grass"/>
        <DrawCuboid x1="-20" y1="4" z1="-20" x2="20" y2="6" z2="20" type="dirt"/>
        <DrawCuboid x1="-20" y1="1" z1="-20" x2="20" y2="3" z2="20" type="stone"/>
      </DrawingDecorator>
      <ServerQuitFromTimeUp timeLimitMs="240000" description="out_of_time"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>agasd</Name>
    <AgentStart>
      <Placement x="1" y="8" z="1" pitch="0" yaw="0"/>
      <Inventory>
        <InventoryItem slot="0" type="wooden_pickaxe" quantity="1"/>
        <InventoryItem slot="1" type="planks" quantity="4"/>
      </Inventory>
    </AgentStart>
    <AgentHandlers>
      <ContinuousMovementCommands/>
      <InventoryCommands/>
      <SimpleCraftCommands/>
      <MissionQuitCommands/>
      <ObservationFromRay/>
      <ObservationFromFullStats/>
      <ObservationFromFullInventory/>
      <ObservationFromGrid>
        <Grid name="nearby">
          <min x="-2" y="-2" z="-2"/>
          <max x="2" y="2" z="2"/>
        </Grid>
      </ObservationFromGrid>
      <RewardForCollectingItem>
        <Item reward="300" type="cobblestone"/>
      </RewardForCollectingItem>
      <RewardForMissionEnd rewardForDeath="-1000">
        <Reward description="found_goal" reward="500"/>
        <Reward description="out_of_time" reward="-250"/>
      </RewardForMissionEnd>
    </AgentHandlers>
  </AgentSection>
</Mission>
