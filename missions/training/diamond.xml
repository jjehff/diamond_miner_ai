<?xml version="1.0" encoding="UTF-8" ?>
<Mission xmlns="http://ProjectMalmo.microsoft.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <About>
    <Summary>mine diamond</Summary>
  </About>

  <ModSettings>
    <MsPerTick>10</MsPerTick> 
  </ModSettings>

  <ServerSection>
    <ServerInitialConditions>
      <AllowSpawning>false</AllowSpawning>
    </ServerInitialConditions>
    <ServerHandlers>
      <FlatWorldGenerator generatorString="3;7,15*1,2*3,2;3;,biome_1"/>
      <DrawingDecorator>
        <DrawCuboid x1="-18" y1="17" z1="-18" x2="18" y2="17" z2="18" type="grass"/>
        <DrawCuboid x1="-18" y1="14" z1="-18" x2="18" y2="16" z2="18" type="dirt"/>
        <DrawCuboid x1="-18" y1="1" z1="-18" x2="18" y2="13" z2="18" type="stone"/>
        <DrawCuboid x1="-1" y1="13" z1="-1" x2="1" y2="14" z2="8" type="air"/>
        <DrawCuboid x1="2" y1="12" z1="7" x2="3" y2="13" z2="8" type="diamond_ore"/>
        <DrawCuboid x1="-5" y1="11" z1="5" x2="-4" y2="12" z2="6" type="diamond_ore"/>
      </DrawingDecorator>
      <ServerQuitFromTimeUp timeLimitMs="300000" description="out_of_time"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>asdasgas</Name>
    <AgentStart>
      <Placement x="1" y="14" z="1" pitch="18" yaw="0"/>
      <Inventory>
        <InventoryItem slot="0" type="iron_pickaxe" quantity="1"/>
        <InventoryItem slot="1" type="torch" quantity="32"/>
        <InventoryItem slot="2" type="planks" quantity="4"/>
      </Inventory>
    </AgentStart>
    <AgentHandlers>
      <ContinuousMovementCommands/>
      <InventoryCommands/>
      <SimpleCraftCommands/>
      <MissionQuitCommands/>
      <ObservationFromRay/>
      <ObservationFromFullStats/>
      <ObservationFromFullInventory/>
      <ObservationFromGrid>
        <Grid name="nearby">
          <min x="-2" y="-2" z="-2"/>
          <max x="2" y="2" z="2"/>
        </Grid>
      </ObservationFromGrid>
      <RewardForCollectingItem>
        <Item reward="1500" type="diamond"/>
      </RewardForCollectingItem>
      <RewardForMissionEnd rewardForDeath="-1000">
        <Reward description="found_goal" reward="1000"/>
        <Reward description="out_of_time" reward="-250"/>
      </RewardForMissionEnd>
      <AgentQuitFromCollectingItem>
        <Item type="diamond" description="found_goal"/>
      </AgentQuitFromCollectingItem>
    </AgentHandlers>
  </AgentSection>
</Mission>
