<?xml version="1.0" encoding="UTF-8" ?>
<Mission xmlns="http://ProjectMalmo.microsoft.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <About>
    <Summary>forage trees</Summary>
  </About>

  <ModSettings>
    <MsPerTick>10</MsPerTick>
  </ModSettings>

  <ServerSection>
    <ServerHandlers>
      <FlatWorldGenerator generatorString="3;7,220*1,5*3,2;3;,biome_1"/>
      <DrawingDecorator>
        <DrawCuboid x1="-24" y1="226" z1="-24" x2="24" y2="226" z2="24" type="grass"/>

        <DrawCuboid x1="6" y1="227" z1="8" x2="6" y2="231" z2="8" type="log"/>
        <DrawCuboid x1="5" y1="232" z1="7" x2="7" y2="232" z2="9" type="log"/>
        <DrawCuboid x1="12" y1="227" z1="-5" x2="12" y2="231" z2="-5" type="log"/>
        <DrawCuboid x1="11" y1="232" z1="-6" x2="13" y2="232" z2="-4" type="log"/>
        <DrawCuboid x1="-9" y1="227" z1="11" x2="-9" y2="232" z2="11" type="log"/>
        <DrawCuboid x1="-10" y1="233" z1="10" x2="-8" y2="233" z2="12" type="log"/>
      </DrawingDecorator>
      <ServerQuitFromTimeUp timeLimitMs="240000" description="out_of_time"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>asgsa</Name>
    <AgentStart>
      <Placement x="1" y="227" z="1" pitch="0" yaw="0"/>
    </AgentStart>
    <AgentHandlers>
      <ContinuousMovementCommands/>
      <InventoryCommands/>
      <SimpleCraftCommands/>
      <MissionQuitCommands/>
      <ObservationFromRay/>
      <ObservationFromFullStats/>
      <ObservationFromFullInventory/>
      <ObservationFromGrid>
        <Grid name="nearby">
          <min x="-2" y="-1" z="-2"/>
          <max x="10" y="3" z="10"/>
        </Grid>
      </ObservationFromGrid>
      <RewardForCollectingItem>
        <Item reward="250" type="log"/>
      </RewardForCollectingItem>
      <RewardForMissionEnd rewardForDeath="-1000">
        <Reward description="found_goal" reward="500"/>
        <Reward description="out_of_time" reward="-250"/>
      </RewardForMissionEnd>
    </AgentHandlers>
  </AgentSection>
</Mission>
